#lang rhombus/static/and_meta

import:
  pict open
  animated_pict_gif open
  rhombus/runtime_path

fun image_equal(a :: StaticPict, b :: StaticPict) :: Boolean:
  a.width == b.width
    && a.height == b.height
    && (frame_bitmap(a).argb_pixels() is_now frame_bitmap(b).argb_pixels())

fun images_equal(as :: List.of(StaticPict), bs :: List.of(StaticPict)) :: Boolean:
  as.length() == bs.length()
    && (for all (a: as, b: bs):
          image_equal(a, b))

expr.macro check_images
| 'check_images:
     $(actual :: expr_meta.Parsed)
     ~is $(expected :: expr_meta.Parsed)':
    ~all_stx stx
    ~op_stx chkimgs
    let chk: Syntax.relocate('check', chkimgs)
    Syntax.relocate_group(
      '$chk:
         images_equal($actual.group, $expected.group)
         ~is #true',
      stx)

def rect1: rectangle(~width: 40, ~height: 20, ~fill: "lightblue")

check_images:
  animated_pict_frames(rect1, 100)
  ~is [rect1]

def late_rect1: rect1.time_pad(~before: 1)

check_images:
  animated_pict_frames(late_rect1, 100)
  ~is [rect1.ghost(), rect1]

def circ1: circle(~size: 40, ~fill: "lightgreen")

def early_circ1 = circ1.time_pad(~after: 1)

check_images:
  animated_pict_frames(early_circ1, 100)
  ~is [circ1, circ1.ghost()]

def ping_pong: stack(early_circ1, late_rect1)

check_images:
  animated_pict_frames(ping_pong, 100)
  ~is [stack(circ1, rect1.ghost()), stack(circ1.ghost(), rect1)]

def together_apart: overlay(early_circ1, late_rect1)

check_images:
  animated_pict_frames(together_apart, 100)
  ~is [circ1, overlay(circ1.ghost(), rect1)]

// TODO: test one_at_a_time and switch, once I understand what's going on there

def fade_out1: animate(fun (n): circ1.alpha(1-n), ~bend: values)

check_images:
  animated_pict_frames(fade_out1, 12)
  ~is [circ1.alpha(1 - (0 / 50.0)),
       circ1.alpha(1 - (12 / 50.0)),
       circ1.alpha(1 - (24 / 50.0)),
       circ1.alpha(1 - (36 / 50.0)),
       circ1.alpha(1 - (48 / 50.0))]

runtime_path.def magic_move_1_actual: "magic_move_1_actual.gif"
runtime_path.def magic_move_1_expect: "magic_move_1_expect.gif"

runtime_path.def magic_move_2_actual: "magic_move_2_actual.gif"
runtime_path.def magic_move_2_expect: "magic_move_2_expect.gif"

expr.macro 'check_file $(actual_expr :: Term) $(expect_expr :: Term): $write_expr':
  ~all_stx stx
  ~op_stx chkf
  let chk: Syntax.relocate('check', chkf)
  'block:
     let actual: $actual_expr
     let expect: $expect_expr
     when filesystem.file_exists(actual)
     | filesystem.delete(actual)
     $write_expr
     $(Syntax.relocate_group(
         '$chk:
            filesystem.read_bytes(actual)
            ~is_now filesystem.read_bytes(expect)',
         stx))
     when filesystem.file_exists(actual)
       && filesystem.read_bytes(actual) is_now filesystem.read_bytes(expect)
     | filesystem.delete(actual)'

block:
  def sq: square(~size: 18, ~fill: "lightblue")
  def cr: circle(~size: 12, ~fill: "pink")
  def tri: triangle(~width: 16, ~fill: "black")
  def pre: beside(sq, cr).scale(1.5)
  def post: beside(~sep: 5, cr, tri, sq)
  def bg: rectangle(~width: 60, ~height: 30, ~fill: "white")
  def magic_move_1: overlay(bg, magic_move(pre, post))
  def magic_move_2: overlay(bg, magic_move(pre, post, ~other: #'fade))
  check_file magic_move_1_actual magic_move_1_expect:
    animated_pict_write_animated_gif(magic_move_1, 8, magic_move_1_actual)
  check_file magic_move_2_actual magic_move_2_expect:
    animated_pict_write_animated_gif(magic_move_2, 8, magic_move_2_actual)

